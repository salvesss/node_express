# Скопируйте в «.env». Для Docker Compose переменные подставляются из «.env» в корне проекта.

# APP_PORT — порт HTTP (не PORT: часто занята в оболочке/CI)
APP_PORT=4000
NODE_ENV=development
LOG_LEVEL=info

POSTGRES_USER=app
POSTGRES_PASSWORD=change_me_in_dot_env
POSTGRES_DB=appdb
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Prisma (PostgreSQL). В docker compose хост = postgres (имя сервиса).
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public

PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me_in_dot_env
PGADMIN_LISTEN_PORT=5050

DOCKERHUB_USER=yourdockerhub_username
IMAGE_TAG=latest
