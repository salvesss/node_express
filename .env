# Copy to ".env" and adjust values (never commit .env).
# Used by docker compose variable substitution and container env.

# --- Application ---
APP_PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# --- PostgreSQL (postgres service + optional app connection) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me_in_dot_env
POSTGRES_DB=appdb
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- pgAdmin (web UI) ---
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me_in_dot_env
PGADMIN_LISTEN_PORT=5050

# --- Image tags for build / docker hub push ---
# Example after login: docker tag ... yourdockerhub/node-express-app:latest
DOCKERHUB_USER=yourdockerhub_username
IMAGE_TAG=latest
